<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/btn_add_manual"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_section_icon_green"
        android:text="@string/add_manual"
        android:textAllCaps="false"
        android:textColor="@color/section_green"
        android:textSize="15sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn_add_receipt"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_section_card"
        android:text="@string/add_from_receipt"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
