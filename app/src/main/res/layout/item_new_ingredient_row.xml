<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_section_card"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_circle_orange">

            <TextView
                android:id="@+id/tv_new_ingredient_number"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/section_orange"
                android:textSize="12sp"
                android:textStyle="bold" />
        </FrameLayout>

        <EditText
            android:id="@+id/et_new_ingredient_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_soft"
            android:hint="@string/ingredient_name_hint"
            android:inputType="textCapSentences"
            android:padding="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btn_remove_ingredient"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_delete_circle"
            android:contentDescription="@string/remove"
            android:padding="7dp"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#C04A4A"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/et_new_ingredient_qty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input_soft"
            android:hint="@string/ingredient_qty_hint"
            android:inputType="numberDecimal"
            android:padding="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <EditText
            android:id="@+id/et_new_ingredient_unit"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_input_soft"
            android:hint="@string/ingredient_unit_hint"
            android:inputType="textCapSentences"
            android:padding="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />
    </LinearLayout>
</LinearLayout>

